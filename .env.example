# =============================================================
# Notification Engine Platform — Environment Variables
# =============================================================
# HOW TO USE:
#   cp .env.example .env
#   Edit .env and fill in the REQUIRED values marked below.
#   Never commit the real .env file — it is in .gitignore.
# =============================================================

# -----------------------------------------------
# General
# -----------------------------------------------
NODE_ENV=production

# -----------------------------------------------
# PostgreSQL
# -----------------------------------------------
POSTGRES_USER=nep_user

# REQUIRED — choose a strong password (no special chars that break URLs)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

POSTGRES_DB=nep_db

# Port exposed on the host machine (PostgreSQL stays at 5432 inside Docker)
POSTGRES_PORT=5432

# -----------------------------------------------
# Backend — NestJS
# -----------------------------------------------
# Port the NestJS server listens on (this is the variable the app reads).
PORT=3000

# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_AT_LEAST_64_CHAR_RANDOM_HEX

JWT_EXPIRES_IN=8h

# -----------------------------------------------
# Database seeding (initial bootstrap only)
# -----------------------------------------------
# Seeding is OFF by default. Set RUN_SEED=true for the FIRST deploy to create
# the initial users, then remove it (or set to false) for subsequent deploys.
# RUN_SEED=true
#
# REQUIRED when RUN_SEED=true in production — no default passwords are used.
# SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# SEED_OPS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# SEED_AUDITOR_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# SEED_VIEWER_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# -----------------------------------------------
# DATABASE_URL — local development only
# -----------------------------------------------
# When running WITHOUT Docker, set this to reach postgres on localhost.
# When running WITH Docker Compose, docker-compose.coolify.yml builds this
# automatically using the postgres service name, so you can leave
# this line commented out or unused.
#
# Local dev (no Docker):
DATABASE_URL=postgresql://nep_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/nep_db?schema=public
#
# Docker Compose / Coolify (auto-set by compose file — do NOT change):
# DATABASE_URL=postgresql://nep_user:<password>@postgres:5432/nep_db?schema=public

# -----------------------------------------------
# CORS
# -----------------------------------------------
# Allowed CORS origin(s). Comma-separated for multiple. Use '*' to reflect any
# origin (NOT recommended). In Docker/Coolify the frontend calls the API
# same-origin through nginx, so CORS usually only matters for local dev.
#   Local dev (ng serve)  →  http://localhost:4200
#   Coolify / production  →  https://your-domain.com  (or leave blank if same-origin)
CORS_ORIGIN=http://localhost:4200

# -----------------------------------------------
# Frontend (Nginx)
# -----------------------------------------------
# Host port for the Nginx container (default 80)
FRONTEND_PORT=80

# NOTE: API_URL is NOT used by the Angular production build.
# In Docker / Coolify the Angular app uses relative URLs (/api/...)
# and Nginx proxies them to the backend container automatically.
# This variable is kept here for documentation purposes only.
# API_URL=http://localhost:3000

# -----------------------------------------------
# ESB Integration (future — replace mock layer)
# -----------------------------------------------
# ESB_BASE_URL=https://esb.internal/api
# ESB_API_KEY=your_esb_api_key_here
# ESB_TIMEOUT_MS=10000

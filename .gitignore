# =============================================================
# Notification Engine Platform — .gitignore
# =============================================================

# ---- Secrets / Environment files ----
# IMPORTANT: never commit real environment files
.env
.env.local
.env.*.local
*.env
.envrc

# ---- Node ----
node_modules/
backend/node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Build output ----
dist/
backend/dist/
frontend/dist/
build/

# ---- Angular ----
.angular/
frontend/.angular/
backend/.angular/

# ---- Coverage / Testing ----
coverage/
.nyc_output/

# ---- Cache / Temp ----
.tmp/
.cache/
*.log

# ---- OS / Editor ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Docker ----
# (don't ignore docker-compose.yml — it should be committed)

# ---- Prisma generated ----
# Generated client is created during build, not tracked
backend/node_modules/.prisma/
